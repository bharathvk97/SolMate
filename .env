APP_NAME="SolMate"
APP_ENV=local
APP_KEY=base64:H0dK5s8Eq0khdbE9LbGP6JmsTKUxb8TWF7pGilTGqUk=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ───────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hostelfindr
DB_USERNAME=root
DB_PASSWORD=

# ─── Queue & Cache ──────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

